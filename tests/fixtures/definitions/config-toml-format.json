{
  "meta": {
    "name": "config-toml-format",
    "description": "FerrFlow config written as ferrflow.toml instead of ferrflow.json"
  },
  "config": {
    "format": "toml",
    "filename": "ferrflow.toml",
    "content": "[workspace]\n\n[[package]]\nname = \"mylib\"\npath = \".\"\n\n[[package.versioned_files]]\npath = \"version.toml\"\nformat = \"toml\"\n"
  },
  "packages": [
    {
      "name": "mylib",
      "path": ".",
      "initial_version": "1.0.0",
      "tag": "v1.0.0"
    }
  ],
  "commits": [
    {
      "message": "feat: add something",
      "files": [
        "src/lib.rs"
      ]
    }
  ],
  "expect": {
    "check_contains": [
      "mylib",
      "1.1.0"
    ],
    "check_not_contains": [
      "Nothing to release"
    ]
  }
}
