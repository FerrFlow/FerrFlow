{
  "meta": {
    "name": "hooks-basic",
    "description": "Hooks defined in config are written as executable scripts in the generated repo"
  },
  "config": {
    "content": "{\n  \"workspace\": {\n    \"hooks\": {\n      \"preBump\": \"./hooks/pre-bump.sh\",\n      \"postBump\": \"./hooks/post-bump.sh\"\n    }\n  },\n  \"package\": [\n    {\n      \"name\": \"mylib\",\n      \"path\": \".\",\n      \"versioned_files\": [{\"path\": \"version.toml\", \"format\": \"toml\"}]\n    }\n  ]\n}\n"
  },
  "packages": [
    {
      "name": "mylib",
      "path": ".",
      "initial_version": "1.0.0",
      "tag": "v1.0.0"
    }
  ],
  "hooks": [
    {
      "path": "hooks/pre-bump.sh",
      "content": "#!/usr/bin/env bash\necho \"pre-bump running\" >> /tmp/ferrflow-hooks.log\n"
    },
    {
      "path": "hooks/post-bump.sh",
      "content": "#!/usr/bin/env bash\necho \"post-bump running\" >> /tmp/ferrflow-hooks.log\n"
    }
  ],
  "commits": [
    {
      "message": "feat: trigger a bump",
      "files": [
        "src/lib.rs"
      ]
    }
  ],
  "expect": {
    "check_contains": [
      "mylib",
      "1.1.0"
    ],
    "check_not_contains": [
      "Nothing to release"
    ]
  }
}
