{
  "meta": {
    "name": "monorepo-two-packages",
    "description": "Two packages both touched in the same commit get independent bumps"
  },
  "config": {
    "content": "{\n  \"package\": [\n    {\n      \"name\": \"core\",\n      \"path\": \"core\",\n      \"versioned_files\": [{\"path\": \"core/version.toml\", \"format\": \"toml\"}]\n    },\n    {\n      \"name\": \"cli\",\n      \"path\": \"cli\",\n      \"versioned_files\": [{\"path\": \"cli/version.toml\", \"format\": \"toml\"}]\n    }\n  ]\n}\n"
  },
  "packages": [
    {
      "name": "core",
      "path": "core",
      "initial_version": "0.1.0",
      "tag": "core@v0.1.0"
    },
    {
      "name": "cli",
      "path": "cli",
      "initial_version": "0.1.0",
      "tag": "cli@v0.1.0"
    }
  ],
  "commits": [
    {
      "message": "feat: add features to both packages",
      "files": [
        "core/src/lib.rs",
        "cli/src/main.rs"
      ]
    }
  ],
  "expect": {
    "check_contains": [
      "core",
      "0.2.0",
      "cli",
      "0.2.0"
    ],
    "check_not_contains": [
      "Nothing to release"
    ],
    "packages_released": 2
  }
}
