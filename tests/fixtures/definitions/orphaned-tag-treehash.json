{
  "meta": {
    "name": "orphaned-tag-treehash",
    "description": "Orphaned tag with treeHash strategy recovers the correct version"
  },
  "config": {
    "content": "{\n  \"workspace\": {\n    \"orphanedTagStrategy\": \"treeHash\"\n  },\n  \"package\": [\n    {\n      \"name\": \"myapp\",\n      \"path\": \".\",\n      \"versioned_files\": [{\"path\": \"version.toml\", \"format\": \"toml\"}]\n    }\n  ]\n}\n"
  },
  "packages": [
    {
      "name": "myapp",
      "path": ".",
      "initial_version": "1.0.0",
      "tag": "v1.0.0"
    }
  ],
  "commits": [
    {
      "message": "feat: add feature",
      "files": [
        "src/lib.rs"
      ]
    }
  ],
  "expect": {
    "check_contains": [
      "myapp",
      "1.1.0"
    ],
    "check_not_contains": [
      "Nothing to release"
    ]
  }
}
