{
  "meta": {
    "name": "recover-missed-releases",
    "description": "With recoverMissedReleases, intermediate versions are created"
  },
  "config": {
    "content": "{\n  \"workspace\": {\n    \"recoverMissedReleases\": true\n  },\n  \"package\": [\n    {\n      \"name\": \"myapp\",\n      \"path\": \".\",\n      \"versioned_files\": [{\"path\": \"version.toml\", \"format\": \"toml\"}]\n    }\n  ]\n}\n"
  },
  "packages": [
    {
      "name": "myapp",
      "path": ".",
      "initial_version": "1.0.0",
      "tag": "v1.0.0"
    }
  ],
  "commits": [
    {
      "message": "feat: first feature",
      "files": [
        "src/one.rs"
      ]
    },
    {
      "message": "feat!: breaking change",
      "files": [
        "src/two.rs"
      ]
    }
  ],
  "expect": {
    "check_contains": [
      "myapp"
    ],
    "check_not_contains": [
      "Nothing to release"
    ]
  }
}
