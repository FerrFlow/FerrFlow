{
  "meta": {
    "name": "tag-custom-template",
    "description": "Custom tag template with non-default pattern"
  },
  "config": {
    "content": "{\n  \"workspace\": {\n    \"tagTemplate\": \"release-{name}-{version}\"\n  },\n  \"package\": [\n    {\n      \"name\": \"myapp\",\n      \"path\": \".\",\n      \"versioned_files\": [{\"path\": \"version.toml\", \"format\": \"toml\"}]\n    }\n  ]\n}\n"
  },
  "packages": [
    {
      "name": "myapp",
      "path": ".",
      "initial_version": "1.0.0"
    }
  ],
  "tags": [
    {
      "name": "release-myapp-1.0.0",
      "at_commit": -1
    }
  ],
  "commits": [
    {
      "message": "feat: add notifications",
      "files": [
        "src/notify.rs"
      ]
    }
  ],
  "expect": {
    "check_contains": [
      "myapp",
      "1.1.0",
      "minor"
    ],
    "check_not_contains": [
      "Nothing to release"
    ]
  }
}
