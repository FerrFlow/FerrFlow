{
  "meta": {
    "name": "versioning-sequential",
    "description": "Sequential versioning uses simple incrementing numbers"
  },
  "config": {
    "content": "{\n  \"workspace\": {\n    \"versioning\": \"sequential\"\n  },\n  \"package\": [\n    {\n      \"name\": \"myapp\",\n      \"path\": \".\",\n      \"versioned_files\": [{\"path\": \"version.toml\", \"format\": \"toml\"}]\n    }\n  ]\n}\n"
  },
  "packages": [
    {
      "name": "myapp",
      "path": ".",
      "initial_version": "42",
      "tag": "v42"
    }
  ],
  "commits": [
    {
      "message": "feat: add feature",
      "files": [
        "src/lib.rs"
      ]
    }
  ],
  "expect": {
    "check_contains": [
      "myapp",
      "43"
    ],
    "check_not_contains": [
      "Nothing to release"
    ]
  }
}
