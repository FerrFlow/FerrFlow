{
  "meta": {
    "name": "versioning-zerover",
    "description": "Zerover keeps major at 0, breaking change bumps minor instead"
  },
  "config": {
    "content": "{\n  \"workspace\": {\n    \"versioning\": \"zerover\"\n  },\n  \"package\": [\n    {\n      \"name\": \"mylib\",\n      \"path\": \".\",\n      \"versioned_files\": [{\"path\": \"version.toml\", \"format\": \"toml\"}]\n    }\n  ]\n}\n"
  },
  "packages": [
    {
      "name": "mylib",
      "path": ".",
      "initial_version": "0.5.0",
      "tag": "v0.5.0"
    }
  ],
  "commits": [
    {
      "message": "feat!: breaking API change",
      "files": [
        "src/api.rs"
      ]
    }
  ],
  "expect": {
    "check_contains": [
      "mylib",
      "0.6.0"
    ],
    "check_not_contains": [
      "Nothing to release",
      "1.0.0"
    ]
  }
}
